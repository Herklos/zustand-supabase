{
  "name": "zustand-supabase-adapter-web",
  "version": "1.0.0",
  "description": "Web platform adapters for zustand-supabase (localStorage, IndexedDB)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Herklos/zustand-supabase.git",
    "directory": "packages/adapter-web"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zustand-supabase": ">=1.0.0"
  },
  "devDependencies": {
    "zustand-supabase": "workspace:*",
    "typescript": "^5.7.0",
    "tsup": "^8.0.0"
  },
  "license": "MIT"
}

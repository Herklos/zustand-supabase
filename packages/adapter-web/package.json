{
  "name": "zustand-supabase-adapter-web",
  "version": "0.1.0",
  "description": "Web platform adapters for zustand-supabase (localStorage, IndexedDB)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zustand-supabase": "*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.0.0"
  },
  "license": "MIT"
}

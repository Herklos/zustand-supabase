{
  "name": "@zustand-supabase/adapter-react-native",
  "version": "0.1.0",
  "description": "React Native platform adapters for zustand-supabase (expo-sqlite, AsyncStorage)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zustand-supabase": "*"
  },
  "peerDependencies": {
    "expo-sqlite": ">=14.0.0",
    "@react-native-async-storage/async-storage": ">=1.0.0",
    "@react-native-community/netinfo": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "expo-sqlite": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "@react-native-community/netinfo": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.0.0"
  },
  "license": "MIT"
}

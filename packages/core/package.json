{
  "name": "@drakkar.software/anchor",
  "version": "1.2.0",
  "description": "Anchor: auto-generated Zustand stores for Supabase, offline-first, realtime, type-safe",
  "repository": {
    "type": "git",
    "url": "https://github.com/Herklos/anchor.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.js"
    },
    "./query": {
      "types": "./dist/query/filters.d.ts",
      "import": "./dist/query/filters.mjs",
      "require": "./dist/query/filters.js"
    },
    "./auth": {
      "types": "./dist/auth/authStore.d.ts",
      "import": "./dist/auth/authStore.mjs",
      "require": "./dist/auth/authStore.js"
    },
    "./realtime": {
      "types": "./dist/realtime/realtimeManager.d.ts",
      "import": "./dist/realtime/realtimeManager.mjs",
      "require": "./dist/realtime/realtimeManager.js"
    },
    "./persistence": {
      "types": "./dist/persistence/persistenceAdapter.d.ts",
      "import": "./dist/persistence/persistenceAdapter.mjs",
      "require": "./dist/persistence/persistenceAdapter.js"
    },
    "./rpc": {
      "types": "./dist/rpc/rpcAction.d.ts",
      "import": "./dist/rpc/rpcAction.mjs",
      "require": "./dist/rpc/rpcAction.js"
    },
    "./sync": {
      "types": "./dist/sync/crossTabSync.d.ts",
      "import": "./dist/sync/crossTabSync.mjs",
      "require": "./dist/sync/crossTabSync.js"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle/appLifecycle.d.ts",
      "import": "./dist/lifecycle/appLifecycle.mjs",
      "require": "./dist/lifecycle/appLifecycle.js"
    },
    "./sync/background": {
      "types": "./dist/sync/backgroundSync.d.ts",
      "import": "./dist/sync/backgroundSync.mjs",
      "require": "./dist/sync/backgroundSync.js"
    },
    "./sync/selective": {
      "types": "./dist/sync/selectiveSync.d.ts",
      "import": "./dist/sync/selectiveSync.mjs",
      "require": "./dist/sync/selectiveSync.js"
    },
    "./sync/multiDevice": {
      "types": "./dist/sync/multiDeviceSync.d.ts",
      "import": "./dist/sync/multiDeviceSync.mjs",
      "require": "./dist/sync/multiDeviceSync.js"
    },
    "./sync/metrics": {
      "types": "./dist/sync/syncMetrics.d.ts",
      "import": "./dist/sync/syncMetrics.mjs",
      "require": "./dist/sync/syncMetrics.js"
    },
    "./persistence/encrypted": {
      "types": "./dist/persistence/encryptedAdapter.d.ts",
      "import": "./dist/persistence/encryptedAdapter.mjs",
      "require": "./dist/persistence/encryptedAdapter.js"
    },
    "./persistence/quota": {
      "types": "./dist/persistence/storageQuota.d.ts",
      "import": "./dist/persistence/storageQuota.mjs",
      "require": "./dist/persistence/storageQuota.js"
    },
    "./persistence/schemaVersion": {
      "types": "./dist/persistence/schemaVersion.d.ts",
      "import": "./dist/persistence/schemaVersion.mjs",
      "require": "./dist/persistence/schemaVersion.js"
    },
    "./mutation/audit": {
      "types": "./dist/mutation/conflictAudit.d.ts",
      "import": "./dist/mutation/conflictAudit.mjs",
      "require": "./dist/mutation/conflictAudit.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "zustand": ">=4.5.0",
    "@supabase/supabase-js": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "immer": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "zustand": "^5.0.0",
    "@supabase/supabase-js": "^2.49.0",
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "react": "^19.0.0",
    "@types/react": "^19.0.0"
  },
  "license": "MIT",
  "keywords": [
    "zustand",
    "supabase",
    "state-management",
    "offline-first",
    "realtime",
    "react"
  ]
}

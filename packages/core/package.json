{
  "name": "zustand-supabase",
  "version": "1.0.0",
  "description": "Zustand + Supabase: auto-generated stores, offline-first, realtime, type-safe",
  "repository": {
    "type": "git",
    "url": "https://github.com/Herklos/zustand-supabase.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs"
    },
    "./query": {
      "types": "./dist/query/filters.d.ts",
      "import": "./dist/query/filters.js",
      "require": "./dist/query/filters.cjs"
    },
    "./auth": {
      "types": "./dist/auth/authStore.d.ts",
      "import": "./dist/auth/authStore.js",
      "require": "./dist/auth/authStore.cjs"
    },
    "./realtime": {
      "types": "./dist/realtime/realtimeManager.d.ts",
      "import": "./dist/realtime/realtimeManager.js",
      "require": "./dist/realtime/realtimeManager.cjs"
    },
    "./persistence": {
      "types": "./dist/persistence/persistenceAdapter.d.ts",
      "import": "./dist/persistence/persistenceAdapter.js",
      "require": "./dist/persistence/persistenceAdapter.cjs"
    },
    "./rpc": {
      "types": "./dist/rpc/rpcAction.d.ts",
      "import": "./dist/rpc/rpcAction.js",
      "require": "./dist/rpc/rpcAction.cjs"
    },
    "./sync": {
      "types": "./dist/sync/crossTabSync.d.ts",
      "import": "./dist/sync/crossTabSync.js",
      "require": "./dist/sync/crossTabSync.cjs"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle/appLifecycle.d.ts",
      "import": "./dist/lifecycle/appLifecycle.js",
      "require": "./dist/lifecycle/appLifecycle.cjs"
    },
    "./sync/background": {
      "types": "./dist/sync/backgroundSync.d.ts",
      "import": "./dist/sync/backgroundSync.js",
      "require": "./dist/sync/backgroundSync.cjs"
    },
    "./sync/selective": {
      "types": "./dist/sync/selectiveSync.d.ts",
      "import": "./dist/sync/selectiveSync.js",
      "require": "./dist/sync/selectiveSync.cjs"
    },
    "./sync/multiDevice": {
      "types": "./dist/sync/multiDeviceSync.d.ts",
      "import": "./dist/sync/multiDeviceSync.js",
      "require": "./dist/sync/multiDeviceSync.cjs"
    },
    "./sync/metrics": {
      "types": "./dist/sync/syncMetrics.d.ts",
      "import": "./dist/sync/syncMetrics.js",
      "require": "./dist/sync/syncMetrics.cjs"
    },
    "./persistence/encrypted": {
      "types": "./dist/persistence/encryptedAdapter.d.ts",
      "import": "./dist/persistence/encryptedAdapter.js",
      "require": "./dist/persistence/encryptedAdapter.cjs"
    },
    "./persistence/quota": {
      "types": "./dist/persistence/storageQuota.d.ts",
      "import": "./dist/persistence/storageQuota.js",
      "require": "./dist/persistence/storageQuota.cjs"
    },
    "./persistence/schemaVersion": {
      "types": "./dist/persistence/schemaVersion.d.ts",
      "import": "./dist/persistence/schemaVersion.js",
      "require": "./dist/persistence/schemaVersion.cjs"
    },
    "./mutation/audit": {
      "types": "./dist/mutation/conflictAudit.d.ts",
      "import": "./dist/mutation/conflictAudit.js",
      "require": "./dist/mutation/conflictAudit.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "zustand": ">=4.5.0",
    "@supabase/supabase-js": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "immer": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "zustand": "^5.0.0",
    "@supabase/supabase-js": "^2.49.0",
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "react": "^19.0.0",
    "@types/react": "^19.0.0"
  },
  "license": "MIT",
  "keywords": [
    "zustand",
    "supabase",
    "state-management",
    "offline-first",
    "realtime",
    "react"
  ]
}
